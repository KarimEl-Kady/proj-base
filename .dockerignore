# Version control
.git
.gitattributes
.gitignore

# Dependencies (installed inside container)
/node_modules
/vendor

# Environment (injected via docker-compose)
.env
.env.backup
.env.production

# IDE / Editor
/.idea
/.vscode
/.cursor
/.zed
/.nova
/.phpactor.json
_ide_helper.php

# Testing artifacts
/.phpunit.cache
/.phpunit.result.cache
/tests
/app/Modules/*/Tests
/app/Vendor/*/tests

# Storage (mounted as volume)
/storage/logs/*
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*

# Docker orchestration files are not needed in the image. The docker/
# directory itself must remain in context because Dockerfile copies PHP and
# entrypoint configuration from it.
docker-compose.yml
docker-compose.override.yml
Makefile

# Build output (rebuilt inside container)
/public/build
/public/hot
/public/fonts-manifest.dev.json

# Generated for the dependency set inside the image. Host caches may contain
# service providers from require-dev packages that do not exist in production.
/bootstrap/cache/*.php

# OS
.DS_Store
Thumbs.db

# Misc
*.log
/auth.json
Homestead.json
Homestead.yaml
AGENTS.md
README.md
