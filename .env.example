APP_NAME=BaseProject
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# -- Docker overrides (uncomment when using docker-compose) --
# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=proj_base
# DB_USERNAME=proj_base
# DB_PASSWORD=secret
# DB_ROOT_PASSWORD=rootsecret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -- Docker Redis overrides (uncomment when using docker-compose) --
# REDIS_HOST=redis
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis

MAIL_MAILER=log
# -- Docker mail override (Mailpit catches all mail in dev) --
# MAIL_MAILER=smtp
# MAIL_HOST=mailpit
# MAIL_PORT=1025
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

### PROJECT CONFIGURATION ###

PROJECT_NAME="${APP_NAME}"
PROJECT_VERSION=1.0.0
PROJECT_DB_DRIVER=mysql
PROJECT_TENANCY_MODE=single
# PROJECT_TENANCY_MODE=multi
PROJECT_TENANT_COLUMN=tenant_id
PROJECT_TENANT_IDENTIFICATION=subdomain
PROJECT_PLATFORM=web
# PROJECT_PLATFORM=api
# PROJECT_PLATFORM=hybrid

PROJECT_API_ENABLED=true
PROJECT_API_PREFIX=api
PROJECT_API_VERSION=v1
PROJECT_API_RATE_LIMIT=60

PROJECT_DASHBOARD_PREFIX=dashboard
PROJECT_API_RESOURCE_WRAP=data
# PROJECT_API_RESOURCE_WITHOUT_WRAPPING=true

PROJECT_AUTH_DRIVER=session
PROJECT_AUTH_TOKEN_EXPIRATION=1440
# Role (local/permission) auto-assigned to new registrations; unset = none
# PROJECT_AUTH_DEFAULT_ROLE=customer


PROJECT_FEATURE_REGISTRATION=true
PROJECT_FEATURE_EMAIL_VERIFICATION=false
PROJECT_FEATURE_2FA=false
PROJECT_FEATURE_API_TOKENS=false

PROJECT_CACHE_PREFIX=proj_base_

PROJECT_PAGINATION_PER_PAGE=15
PROJECT_PAGINATION_MAX_PER_PAGE=100

### LOCAL PACKAGES (app/Vendor) ###

# PROJECT_VENDOR_COMPOSER=local
# PROJECT_VENDOR_NAMESPACE=Local

# MEDIA_DISK=public
# MEDIA_DIRECTORY=media
# MEDIA_MAX_FILE_SIZE=10240

# GEO_SEED_COUNTRIES=EG,KW,AE,SA

# PERMISSION_CACHE_ENABLED=true
# PERMISSION_CACHE_TTL=3600

### DOCKER ###

APP_PORT=80
VITE_PORT=5173
FORWARD_DB_PORT=3306
MAILPIT_PORT=8025
MAILPIT_SMTP_PORT=1025
AUTO_MIGRATE=true
# INSTALL_XDEBUG=true
# UID=1000
# GID=1000
