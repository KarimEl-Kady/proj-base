APP_NAME=BaseProject
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Comma-separated proxy IPs/CIDRs; configure at the load-balancer boundary
# TRUSTED_PROXIES=10.0.0.0/8
# Browser API origins; empty blocks cross-origin browser requests
# CORS_ALLOWED_ORIGINS=https://app.example.com
CORS_SUPPORTS_CREDENTIALS=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# DB_CONNECTION, CACHE_STORE, SESSION_DRIVER, and QUEUE_CONNECTION are left
# unset below on purpose, not defaulted to sqlite/database explicitly.
# Laravel's own config defaults (config/database.php, cache.php, session.php,
# queue.php) already fall back to sqlite/database for a zero-service local
# quick start — so leaving these unset changes nothing for that path — while
# docker-compose.yml's own defaults (${DB_CONNECTION:-mysql},
# ${CACHE_STORE:-redis}, etc.) only take effect when a variable is genuinely
# unset. Setting any of these explicitly here, even to a value that matches
# Laravel's own default, would silently block the Docker default too and
# leave a `cp .env.example .env` Docker setup quietly running against
# SQLite/the database driver instead of MySQL/Redis. Uncomment a line only
# to force a specific driver outside Docker.
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_DRIVER=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# QUEUE_CONNECTION=redis

# CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# REDIS_HOST=redis is set unconditionally by docker-compose.yml itself
# (not interpolated from this file), so nothing to uncomment here for Docker.

MAIL_MAILER=log
# -- Docker mail override (Mailpit catches all mail in dev) --
# MAIL_MAILER=smtp
# MAIL_HOST=mailpit
# MAIL_PORT=1025
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

### PROJECT CONFIGURATION ###

PROJECT_NAME="${APP_NAME}"
PROJECT_VERSION=1.0.0
# Tenancy: none (no tenancy), single (one implicit default tenant),
# multi (tenant resolved per request via PROJECT_TENANT_IDENTIFICATION)
PROJECT_TENANCY_MODE=none
# PROJECT_TENANCY_MODE=single
# PROJECT_TENANCY_MODE=multi
PROJECT_TENANT_COLUMN=tenant_id
PROJECT_TENANT_IDENTIFICATION=subdomain
# Multi-tenant self-registration is closed unless explicitly opened.
PROJECT_TENANT_REGISTRATION=closed
# Fail closed when tenant-scoped models are used without a tenant in Context
# (CLI/seeders/cron) — wrap such code in with_tenant()/without_tenant_scope()
# PROJECT_TENANCY_STRICT=true
# Single mode's implicit tenant (created on first use):
# PROJECT_TENANT_DEFAULT_NAME=Default
# PROJECT_TENANT_DEFAULT_SLUG=default
# Identifier -> tenant id resolution cache (flushed automatically on tenant writes)
# PROJECT_TENANCY_CACHE_ENABLED=true
# PROJECT_TENANCY_CACHE_TTL=3600
PROJECT_PLATFORM=web
# PROJECT_PLATFORM=api
# PROJECT_PLATFORM=hybrid

PROJECT_API_ENABLED=true
PROJECT_API_PREFIX=api
PROJECT_API_VERSION=v1
PROJECT_API_RATE_LIMIT=60

# Content-Security-Policy sent on the "web"/dashboard group only (see
# SecurityHeadersMiddleware). Left unset until your project has a real
# frontend to write a policy against — a guessed default would just as
# likely break asset loading as protect anything.
# PROJECT_SECURITY_CSP="default-src 'self'"

PROJECT_DASHBOARD_PREFIX=dashboard
PROJECT_API_RESOURCE_WRAP=data
# PROJECT_API_RESOURCE_WITHOUT_WRAPPING=true

# sanctum (recommended Bearer-token driver) | token
PROJECT_AUTH_DRIVER=sanctum
PROJECT_AUTH_TOKEN_EXPIRATION=1440
# Named integration tokens default to 30 days
PROJECT_AUTH_PERSONAL_TOKEN_EXPIRATION=43200
# Role (local/permission) auto-assigned to new registrations; unset = none
# PROJECT_AUTH_DEFAULT_ROLE=customer


# Max rows a ?pagination=false fetch may return (memory guard)
# PROJECT_PAGINATION_UNPAGINATED_CAP=1000

PROJECT_FEATURE_REGISTRATION=true
PROJECT_FEATURE_EMAIL_VERIFICATION=false
PROJECT_FEATURE_2FA=false
# Named personal access token management (Auth /tokens endpoints) — login
# bearer tokens are always issued regardless of this flag
PROJECT_FEATURE_PERSONAL_ACCESS_TOKENS=false

PROJECT_CACHE_PREFIX=proj_base_

PROJECT_PAGINATION_PER_PAGE=15
PROJECT_PAGINATION_MAX_PER_PAGE=100

# Production readiness checks
PROJECT_HEALTH_REQUIRE_QUEUE_WORKER=false
# Keep dependency drivers, latency, backlog, and heartbeat details private.
PROJECT_HEALTH_EXPOSE_DETAILS=false
# Production validation rejects node-local disks unless explicitly waived.
PROJECT_REQUIRE_SHARED_STORAGE=true
PROJECT_HEALTH_QUEUE_HEARTBEAT_TTL=120
PROJECT_HEALTH_QUEUE_BACKLOG_WARNING=1000

# Transactional outbox retry/dead-letter and retention policy
PROJECT_OUTBOX_MAX_ATTEMPTS=10
PROJECT_OUTBOX_CLAIM_TTL=300
PROJECT_OUTBOX_PUBLISHED_RETENTION=168
PROJECT_OUTBOX_FAILED_RETENTION=720
PROJECT_INBOX_PROCESSED_RETENTION=720

# Queued listeners (Core QueuedListener): three named lanes with independent
# workers so one workload cannot consume another lane's reserved capacity.
PROJECT_EVENTS_QUEUE_DEFAULT=default
PROJECT_EVENTS_QUEUE_BULK=bulk
PROJECT_EVENTS_QUEUE_NOTIFICATIONS=notifications
# PROJECT_EVENTS_TRIES=3

### LOCAL PACKAGES (app/Vendor) ###

# PROJECT_VENDOR_COMPOSER=local
# PROJECT_VENDOR_NAMESPACE=Local

# Private local storage in development; use s3/object storage in production.
# MEDIA_DISK=local
# MEDIA_DIRECTORY=media
# MEDIA_MAX_FILE_SIZE=10240
# MEDIA_TEMPORARY_URLS=true
# MEDIA_TEMPORARY_URL_TTL=5

# GEO_SEED_COUNTRIES=EG,KW,AE,SA

# PERMISSION_CACHE_ENABLED=true
# PERMISSION_CACHE_TTL=3600

### DOCKER ###

APP_PORT=80
VITE_PORT=5173
FORWARD_DB_PORT=3306
MAILPIT_PORT=8025
MAILPIT_SMTP_PORT=1025
AUTO_MIGRATE=false
# INSTALL_XDEBUG=true
# UID=1000
# GID=1000
