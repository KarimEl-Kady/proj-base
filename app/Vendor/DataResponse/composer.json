{
    "name": "local/data-response",
    "description": "Standardized JSON response envelope (success/message/data/errors) — local path package",
    "type": "library",
    "version": "1.0.0",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.0",
        "illuminate/http": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Local\\DataResponse\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Local\\DataResponse\\DataResponseServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
