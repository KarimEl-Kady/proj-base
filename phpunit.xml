<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Modules">
            <directory>app/Modules/*/Tests</directory>
        </testsuite>
        <testsuite name="Packages">
            <directory>app/Vendor/*/tests</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
        <exclude>
            <directory>app/Modules/*/Tests</directory>
            <directory>app/Vendor/*/tests</directory>
        </exclude>
    </source>
    <php>
        <!--
            The authoritative override is tests/bootstrap.php, not this block:
            PHPUnit's <env force="true"> only reliably sets $_ENV/putenv(), not
            $_SERVER, and Laravel's env() helper checks $_SERVER first — so
            inside the Docker app container, where docker-compose.yml sets real
            DB_CONNECTION=mysql/CACHE_STORE=redis directly as process
            environment variables (mirrored into $_SERVER by the CLI SAPI at
            startup), force="true" alone is a no-op and `make test` would
            silently run the suite against the live dev MySQL database and a
            real, cross-run-persistent Redis cache. tests/bootstrap.php sets
            $_SERVER explicitly before vendor/autoload.php ever boots the
            framework. This block is kept as a second, harmless layer — it's
            what actually matters in environments (CI, bare host) where
            $_SERVER was never pre-populated with production-like values.
        -->
        <env name="APP_ENV" value="testing" force="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file" force="true"/>
        <env name="BCRYPT_ROUNDS" value="4" force="true"/>
        <env name="BROADCAST_CONNECTION" value="null" force="true"/>
        <env name="CACHE_STORE" value="array" force="true"/>
        <env name="DB_CONNECTION" value="sqlite" force="true"/>
        <env name="DB_DATABASE" value=":memory:" force="true"/>
        <env name="DB_URL" value="" force="true"/>
        <env name="MAIL_MAILER" value="array" force="true"/>
        <env name="QUEUE_CONNECTION" value="sync" force="true"/>
        <env name="SESSION_DRIVER" value="array" force="true"/>
        <env name="PULSE_ENABLED" value="false" force="true"/>
        <env name="TELESCOPE_ENABLED" value="false" force="true"/>
        <env name="NIGHTWATCH_ENABLED" value="false" force="true"/>
    </php>
</phpunit>
